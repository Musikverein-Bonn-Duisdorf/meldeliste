# Webroot hardening (MELD-105)
RedirectMatch 403 /\.git
RedirectMatch 403 /scripts/

<FilesMatch "\.php~$">
    Require all denied
</FilesMatch>

<Files "config.php">
    Require all denied
</Files>

# Branded error pages (MELD-122)
ErrorDocument 403 /errors/403.php
ErrorDocument 404 /errors/404.php
ErrorDocument 500 /errors/500.php
